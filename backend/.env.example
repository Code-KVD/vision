# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ─── Database ─────────────────────────────────────────────────────────────────
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://vision:vision_secret@localhost:5432/vision_db
DB_POOL_MIN=5
DB_POOL_MAX=20

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_secure_random_string_at_least_32_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── Cache TTLs (seconds) ─────────────────────────────────────────────────────
CACHE_TTL_PREDICTIONS=30
CACHE_TTL_LEADERBOARD=60
CACHE_TTL_USER_PROFILE=300

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173
